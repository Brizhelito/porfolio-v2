---
import BaseLayout from '@layouts/BaseLayout.astro';
import TechnicalCard from '@components/ui/TechnicalCard';
import Stamp from '@components/ui/Stamp';
import StickyNote from '@components/ui/StickyNote';
import { t } from '@lib/i18n';

const T = (key: string) => t('en', key);

const collaborations = [
  {
    id: 'corpozulia-2024',
    organization: 'Corpozulia',
    role: 'Development Consultant',
    period: '2024',
    status: 'green' as const,
    statusLabel: T('common.completed'),
    description: 'Technical advisory on modernizing the institutional management platform. Migration from legacy architecture to modern stack with focus on performance and maintainability.',
    contributions: [
      'Audit of existing frontend architecture',
      'Migration proposal to modular components',
      'Internal team training on best practices',
      'Technical documentation and style guides',
    ],
    stack: ['TypeScript', 'React', 'Node.js', 'PostgreSQL'],
    fields: [
      { label: 'ORGANIZATION', value: 'Corpozulia' },
      { label: 'ROLE', value: 'Development Consultant' },
      { label: 'PERIOD', value: '2024' },
      { label: 'MODALITY', value: 'Remote / On-site (Maracaibo)' },
    ],
    // P3-03: anecdote moved into data array (no more template hardcoded text)
    anecdote:
      'The Corpozulia team was exceptionally receptive. The migration was completed in phases with zero downtime.',
  },
];
---

<BaseLayout title={T('collaborations.pageTitle')} description={T('collaborations.pageDescription')} locale="en">
  <section class="page-enter mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">{T('collaborations.header')}</span>
        <Stamp label={`${collaborations.length} RECORD`} variant="green" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]">{T('collaborations.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl">{T('collaborations.subtitle')}</p>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <div class="space-y-8">
      {collaborations.map((collab) => (
        <article class="relative">
          <div class="rounded-paper texture-aged-paper border border-[var(--color-archive-kraft)]/30 p-6 shadow-paper">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h2 class="font-display text-display-sm text-[var(--color-text-primary)]">{collab.organization}</h2>
                  <Stamp label={collab.statusLabel} variant={collab.status} size="sm" animate={false} />
                </div>
                <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] mb-3">{collab.role} · {collab.period}</p>
                <p class="text-body-md text-[var(--color-text-secondary)] mb-4 max-w-xl">{collab.description}</p>
                <div class="mb-4">
                  <p class="font-stamp text-stamp-label text-[var(--color-text-secondary)] mb-2">{T('collaborations.keyContributions')}</p>
                  <ul class="space-y-1">
                    {collab.contributions.map((c) => (
                      <li class="flex items-start gap-2 text-body-sm text-[var(--color-text-primary)]">
                        <span class="mt-1 text-[var(--color-accent-gold)]">◆</span>{c}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="flex flex-wrap gap-2">
                  {collab.stack.map((tech) => (
                    <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-[var(--color-archive-kraft)]/20 text-[var(--color-text-secondary)]">{tech}</span>
                  ))}
                </div>
              </div>
              <div class="lg:w-64 shrink-0">
                <TechnicalCard client:visible title={T('common.technicalCard')} fields={collab.fields} stampLabel={collab.statusLabel} stampVariant={collab.status} />
              </div>
            </div>
          </div>
          <div class="mt-4 ml-8">
            <StickyNote client:visible color="yellow" rotation={-1.5}>
              <p class="text-[var(--color-text-primary)]">
                {collab.anecdote ?? 'Documented collaboration.'}
              </p>
            </StickyNote>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-16 rounded-paper border border-dashed border-[var(--color-accent-gold)]/40 p-8 text-center">
      <p class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-2">{T('collaborations.interested')}</p>
      <p class="text-body-md text-[var(--color-text-secondary)] max-w-md mx-auto mb-4">{T('collaborations.interestedText')}</p>
      <a href="/en/contact" class="gold-underline inline-block font-stamp text-stamp-label text-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] transition-colors">{T('collaborations.openRequest')}</a>
    </div>
  </section>
</BaseLayout>
