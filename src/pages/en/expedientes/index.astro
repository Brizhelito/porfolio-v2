---
import BaseLayout from '@layouts/BaseLayout.astro';
import FileFolder from '@components/ui/FileFolder';
import Stamp from '@components/ui/Stamp';
import { getCollection } from 'astro:content';
import { t } from '@lib/i18n';

const T = (key: string) => t('en', key);
const strings = { refinements: T('common.refinements'), clickToOpen: T('common.clickToOpen') };

const expedientes = await getCollection('expedientes_en');
const sorted = [...expedientes].sort((a, b) => b.data.refinementCount - a.data.refinementCount);

const featured = sorted.filter((e) => e.data.status === 'featured');
const active = sorted.filter((e) => e.data.status === 'active');
const archived = sorted.filter((e) => e.data.status === 'archived');
---

<BaseLayout title={T('expedients.pageTitle')} description={T('expedients.pageDescription')} locale="en">
  <section class="page-enter mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">{T('expedients.archiveTitle')}</span>
        <Stamp label={`${sorted.length} EXPEDIENTS`} variant="blue" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]">{T('expedients.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl">{T('expedients.subtitle')}</p>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    {featured.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-4">{T('expedients.featured')}</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {featured.map((exp) => (
            <a href={`/en/expedientes/${exp.id}`} class="block" data-seal-react>
              <FileFolder client:visible title={exp.data.title} expedientNumber={exp.data.expedientNumber} status={exp.data.status} refinementCount={exp.data.refinementCount} strings={strings}>
                <p class="text-body-sm text-[var(--color-text-secondary)]">{exp.data.description.slice(0, 120)}...</p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {exp.data.stack.slice(0, 5).map((tech) => (
                    <span class="font-mono text-[10px] px-2 py-0.5 rounded bg-[var(--color-archive-kraft)]/10 text-[var(--color-text-secondary)]">{tech}</span>
                  ))}
                </div>
              </FileFolder>
            </a>
          ))}
        </div>
      </div>
    )}

    {active.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-text-secondary)] mb-4">{T('expedients.active')}</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {active.map((exp) => (
            <a href={`/en/expedientes/${exp.id}`} class="block" data-seal-react>
              <FileFolder client:visible title={exp.data.title} expedientNumber={exp.data.expedientNumber} status={exp.data.status} refinementCount={exp.data.refinementCount} strings={strings}>
                <p class="text-body-sm text-[var(--color-text-secondary)]">{exp.data.description.slice(0, 120)}...</p>
              </FileFolder>
            </a>
          ))}
        </div>
      </div>
    )}

    {archived.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-text-secondary)]/60 mb-4">{T('expedients.archived')}</h2>
        <div class="grid gap-4 sm:grid-cols-2 opacity-80">
          {archived.map((exp) => (
            <a href={`/en/expedientes/${exp.id}`} class="block" data-seal-react>
              <FileFolder client:visible title={exp.data.title} expedientNumber={exp.data.expedientNumber} status={exp.data.status} refinementCount={exp.data.refinementCount} strings={strings} />
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
