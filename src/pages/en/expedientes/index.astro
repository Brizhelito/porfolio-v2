---
import BaseLayout from '@layouts/BaseLayout.astro';
import Stamp from '@components/ui/Stamp';
import EvidenceBoard from '@components/expedientes/EvidenceBoard';
import { getCollection } from 'astro:content';
import { t } from '@lib/i18n';

const T = (key: string) => t('en', key);
const strings = {
  refinements: T('common.refinements'),
  clickToOpen: T('common.clickToOpen'),
  active: T('common.active'),
  archived: T('common.archived'),
  featured: T('common.featured'),
  archivedPlural: T('common.archivedPlural'),
  open: T('common.open'),
};

const expedientes = await getCollection('expedientes_en');
const sorted = [...expedientes].sort((a, b) => b.data.refinementCount - a.data.refinementCount);

const boardItems = sorted.map((e) => ({
  id: e.id,
  title: e.data.title,
  expedientNumber: e.data.expedientNumber,
  status: e.data.status,
  refinementCount: e.data.refinementCount,
  description: e.data.description,
  stack: e.data.stack,
  metrics: e.data.metrics,
}));
---

<BaseLayout title={T('expedients.pageTitle')} description={T('expedients.pageDescription')} locale="en">
  <section class="page-enter mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Page header -->
    <header class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">
          {T('expedients.archiveTitle')}
        </span>
        <Stamp label={`${sorted.length} ${T('common.expedientsCount')}`} variant="blue" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]">{T('expedients.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl">
        {T('expedients.subtitle')}
      </p>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <!-- Evidence Board -->
    <EvidenceBoard
      client:visible
      items={boardItems}
      basePath="/en/expedientes"
      strings={strings}
    />
  </section>
</BaseLayout>
