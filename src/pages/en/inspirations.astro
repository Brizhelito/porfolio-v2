---
import BaseLayout from '@layouts/BaseLayout.astro';
import Stamp from '@components/ui/Stamp';
import { t } from '@lib/i18n';

const T = (key: string) => t('en', key);

const categories = [
  { section: 'PHILOSOPHY & METHODOLOGY', entries: [
    { name: 'Kintsugi (金継ぎ)', role: 'Philosophy of repair', note: 'Scars are not hidden — they are celebrated with gold. The conceptual basis of this archive: every documented error, every refactor, and every ADR is a visible part of the process, not something to hide. Expedients show decisions, dead ends, and refinements alike.' },
    { name: 'Richard Feynman', role: 'First-principle thinking', note: '"What I cannot create, I do not understand." The methodology of every expedient: learn by building from scratch, not by copying patterns without understanding them.' },
  ]},
];
---

<BaseLayout title={T('inspirations.pageTitle')} description={T('inspirations.pageDescription')} locale="en">
  <section class="page-enter mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-16 text-center">
      <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">{T('inspirations.header')}</span>
      <h1 class="mt-3 font-display text-display-xl text-[var(--color-text-primary)]">{T('inspirations.title')}</h1>
      <p class="mt-3 text-body-lg text-[var(--color-text-secondary)] max-w-lg mx-auto">{T('inspirations.subtitle')}</p>
      <div class="mt-8 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <div class="space-y-16">
      {categories.map((cat) => (
        <section>
          <h2 class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-8 text-center">{cat.section}</h2>
          <div class="space-y-8">
            {cat.entries.map((entry) => (
              // P2-12: removed group-hover affordance from non-interactive
              // entries. Hovering suggested clickability that doesn't exist.
              <div class="text-center">
                <p class="font-display text-display-sm text-[var(--color-text-primary)]">{entry.name}</p>
                <p class="mt-1 font-stamp text-stamp-label text-[var(--color-text-secondary)]">{entry.role}</p>
                <p class="mt-2 text-body-sm text-[var(--color-text-secondary)] max-w-md mx-auto italic">&ldquo;{entry.note}&rdquo;</p>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="my-16 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />

    <div class="text-center">
      <Stamp label={T('inspirations.end')} variant="red" size="lg" />
      <p class="mt-6 font-handwritten text-body-lg text-[var(--color-text-secondary)] max-w-sm mx-auto">"{T('inspirations.epilogue')}"</p>
      <a href="/en" class="gold-underline mt-6 inline-block font-stamp text-stamp-label text-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] transition-colors">{T('inspirations.back')}</a>
    </div>
  </section>
</BaseLayout>
