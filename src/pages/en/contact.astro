---
import BaseLayout from '@layouts/BaseLayout.astro';
import Stamp from '@components/ui/Stamp';
import StickyNote from '@components/ui/StickyNote';
import { SOCIAL_LINKS } from '@lib/constants';
import { t } from '@lib/i18n';

const T = (key: string) => t('en', key);

// P2-03: emoji → SVG icon keys. The SVG markup is rendered inline below
// via a small lookup map (Astro frontmatter can't return JSX directly).
const channels = [
  {
    id: 'email',
    label: T('contact.email'),
    value: 'renymireles@outlook.com',
    href: SOCIAL_LINKS.email,
    icon: 'email' as const,
    priority: T('contact.emailPriority'),
    variant: 'green' as const,
    description: T('contact.emailDesc'),
  },
  {
    id: 'github',
    label: T('contact.github'),
    value: '@Brizhelito',
    href: SOCIAL_LINKS.github,
    icon: 'github' as const,
    priority: T('contact.githubPriority'),
    variant: 'blue' as const,
    description: T('contact.githubDesc'),
  },
  {
    id: 'linkedin',
    label: T('contact.linkedin'),
    value: '/in/reny-david-mireles-bozo-523147240',
    href: SOCIAL_LINKS.linkedin,
    icon: 'linkedin' as const,
    priority: T('contact.linkedinPriority'),
    variant: 'blue' as const,
    description: T('contact.linkedinDesc'),
  },
  {
    id: 'whatsapp',
    label: T('contact.whatsapp'),
    value: '+58 424-609-1499',
    href: SOCIAL_LINKS.whatsapp,
    icon: 'whatsapp' as const,
    priority: T('contact.whatsappPriority'),
    variant: 'red' as const,
    description: T('contact.whatsappDesc'),
  },
];
---

<BaseLayout title={T('contact.pageTitle')} description={T('contact.pageDescription')} locale="en">
  <section class="page-enter mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">{T('contact.header')}</span>
        <Stamp label={T('common.available')} variant="green" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]">{T('contact.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl">{T('contact.subtitle')}</p>
      {/* P3-06: location pill moved up — clients need timezone/remote info first */}
      <div class="mt-4 inline-flex items-center gap-2 rounded-paper border border-[var(--color-archive-kraft)]/30 bg-[var(--color-bg-secondary)]/40 px-3 py-1.5">
        <svg class="h-4 w-4 text-[var(--color-accent-gold)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
        <span class="font-mono text-caption text-[var(--color-text-secondary)]">
          {T('contact.location')} · UTC-4 · {T('contact.remoteAvailable')}
        </span>
      </div>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <div class="grid gap-6 sm:grid-cols-2">
      {channels.map((ch) => (
        <a href={ch.href} target="_blank" rel="noopener noreferrer"
          class="group relative rounded-paper texture-aged-paper border border-[var(--color-archive-kraft)]/30 p-6 shadow-paper transition-all hover:border-[var(--color-accent-gold)]/40 hover:shadow-paper-hover"
          data-seal-react>
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-3">
              {/* P2-03: SVG icons via inline conditional rendering. */}
              <span class="text-[var(--color-accent-gold)]">
                {ch.icon === 'email' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 7.5L12 13l9-5.5" />
                    <rect x="3" y="5" width="18" height="14" rx="2" />
                  </svg>
                )}
                {ch.icon === 'github' && (
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.17c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.31-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.4s2.04.13 3 .4c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.87.12 3.18.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                )}
                {ch.icon === 'linkedin' && (
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z" />
                  </svg>
                )}
                {ch.icon === 'whatsapp' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 21l1.65-4.5a8.5 8.5 0 1 1 3.85 3.85L3 21z" />
                    <path d="M9 9.5c0 2.5 2 4.5 4.5 4.5 .5 0 1-.3 1-.8v-1l-1.5-.5-.7.7c-.8-.4-1.5-1.1-1.9-1.9l.7-.7L10.5 8h-1c-.3 0-.5.5-.5 1z" />
                  </svg>
                )}
              </span>
              <div>
                <h3 class="font-display text-display-xs text-[var(--color-text-primary)]">{ch.label}</h3>
                <p class="font-mono text-body-sm text-[var(--color-text-secondary)]">{ch.value}</p>
              </div>
            </div>
            <Stamp label={ch.priority} variant={ch.variant} size="sm" animate={false} />
          </div>
          <p class="text-body-sm text-[var(--color-text-secondary)] mb-3">{ch.description}</p>
          <span class="font-stamp text-stamp-label text-[var(--color-accent-gold)] opacity-0 transition-opacity group-hover:opacity-100">{T('common.access')}</span>
        </a>
      ))}
    </div>

    {/* P2-04: project stamp colors instead of Tailwind defaults */}
    <div class="mt-12 rounded-paper border border-dashed border-[var(--color-archive-kraft)]/40 p-6">
      <h2 class="font-stamp text-stamp-title text-[var(--color-text-secondary)] mb-4">{T('contact.responseTimes')}</h2>
      <div class="grid gap-3 sm:grid-cols-3 text-body-sm">
        <div class="flex items-center gap-2"><span class="inline-block h-2 w-2 rounded-full bg-[var(--color-stamp-green)]" /><span class="text-[var(--color-text-secondary)]">{T('contact.responseEmail')}</span></div>
        <div class="flex items-center gap-2"><span class="inline-block h-2 w-2 rounded-full bg-[var(--color-stamp-blue)]" /><span class="text-[var(--color-text-secondary)]">{T('contact.responseLinkedin')}</span></div>
        <div class="flex items-center gap-2"><span class="inline-block h-2 w-2 rounded-full bg-[var(--color-stamp-red)]" /><span class="text-[var(--color-text-secondary)]">{T('contact.responseWhatsapp')}</span></div>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-6">
      <StickyNote client:visible color="blue" rotation={-2}><p class="text-[var(--color-text-primary)]">{T('contact.freelanceTip')}</p></StickyNote>
      <StickyNote client:visible color="pink" rotation={2}><p class="text-[var(--color-text-primary)]">{T('contact.timezoneTip')}</p></StickyNote>
    </div>

    {/* P3-06: location stamp at end removed — moved to header above */}
  </section>
</BaseLayout>
