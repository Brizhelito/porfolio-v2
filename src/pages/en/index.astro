---
import BaseLayout from '@layouts/BaseLayout.astro';
import ScatteredExpedientes from '@components/expedientes/ScatteredExpedientes';
import Seal from '@components/ui/Seal';
import FileFolder from '@components/ui/FileFolder';
import CursorToggle from '@components/ui/CursorToggle';
import LanguageSwitch from '@components/ui/LanguageSwitch';
import { getCollection } from 'astro:content';
import { t, getLocalizedHref } from '@lib/i18n';

const locale = 'en' as const;
const T = (key: string) => t(locale, key);
const currentPath = Astro.url.pathname;

const expedientes = await getCollection('expedientes_en');
const totalRefinements = expedientes.reduce((sum, e) => sum + e.data.refinementCount, 0);

// Separate Kumoriya (flagship) from the rest
const kumoriya = expedientes.find((e) => e.id === 'kumoriya');
const otherExpedientes = expedientes
  .filter((e) => e.id !== 'kumoriya' && (e.data.status === 'featured' || e.data.status === 'active'))
  .sort((a, b) => b.data.refinementCount - a.data.refinementCount)
  .map((e) => ({
    id: e.id,
    title: e.data.title,
    expedientNumber: e.data.expedientNumber,
    status: e.data.status,
    refinementCount: e.data.refinementCount,
  }));

const scatteredStrings = {
  refinements: T('common.refinements'),
  openExpedient: T('common.clickToOpen'),
};

const expedientesHref = getLocalizedHref('/expedientes', locale);
const aboutHref = getLocalizedHref('/about', locale);
const toolsHref = getLocalizedHref('/tools', locale);
const contactHref = getLocalizedHref('/contacto', locale);
---

<BaseLayout locale="en">
  <!-- Hero: Full viewport, split layout -->
  <section
    class="page-enter relative flex min-h-[100dvh] flex-col mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"
    data-lamp-section="hero"
  >
    <!-- Floating controls (always visible without scroll) -->
    <div class="flex items-center justify-end gap-2 pt-4">
      <CursorToggle client:load />
      <LanguageSwitch client:load currentPath={currentPath} locale={locale} />
    </div>

    <!-- Main hero content: centered vertically, split left/right on desktop -->
    <div class="flex flex-1 flex-col items-center justify-center gap-10 lg:flex-row lg:items-center lg:justify-between lg:gap-16">

      <!-- Left: Seal + Name + CTAs -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left lg:flex-1 lg:max-w-lg">
        <Seal client:load size="xl" variant="hero" className="mb-6" />

        <h1 class="text-display-xl text-[var(--color-text-primary)]">
          Reny Mireles
        </h1>

        <p class="mt-3 text-body-lg text-[var(--color-text-secondary)] max-w-md">
          {T('hero.subtitle')}<br />
          {T('hero.subtitleDetail')}
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-4 text-caption">
          <span class="font-mono text-[var(--color-accent-gold)]">
            {expedientes.length} {T('hero.expedientsOpen')}
          </span>
          <span class="text-[var(--color-archive-kraft)]">·</span>
          <span class="font-mono text-[var(--color-text-secondary)]">
            {totalRefinements} {T('hero.totalRefinements')}
          </span>
        </div>

        <div class="mt-2">
          <span class="font-stamp text-stamp-label text-stamp-green">{T('hero.status')}</span>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={expedientesHref} class="inline-flex items-center gap-2 rounded-[3px] border border-[var(--color-accent-gold)] bg-[var(--color-accent-gold)]/10 px-5 py-2.5 font-stamp text-stamp-label text-[var(--color-accent-gold)] transition-all hover:bg-[var(--color-accent-gold)]/20 hover:border-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] hover:shadow-paper" data-seal-react>
            {T('hero.ctaProjects')}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href={contactHref} class="inline-flex items-center gap-2 rounded-[3px] border border-[var(--color-archive-kraft)]/40 px-5 py-2.5 font-stamp text-stamp-label text-[var(--color-text-secondary)] transition-all hover:border-[var(--color-accent-gold)]/40 hover:text-[var(--color-text-primary)] hover:shadow-paper" data-seal-react>
            {T('hero.ctaContact')}
          </a>
        </div>
      </div>

      <!-- Right: Kumoriya "thrown on desk" -->
      {kumoriya && (
        <div class="relative w-full max-w-md lg:flex-1 lg:max-w-lg">
          <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] mb-2 text-center lg:text-left">
            {T('hero.featuredProject')}
          </p>
          <a
            href={`/en/expedientes/${kumoriya.id}`}
            class="block"
            style="transform: rotate(-3deg); transition: transform 0.3s ease;"
            onmouseenter="this.style.transform='rotate(0deg) scale(1.02)'"
            onmouseleave="this.style.transform='rotate(-3deg)'"
            data-seal-react
          >
            <FileFolder
              client:load
              title={kumoriya.data.title}
              expedientNumber={kumoriya.data.expedientNumber}
              status={kumoriya.data.status}
              refinementCount={kumoriya.data.refinementCount}
              variant="hero"
              classification={kumoriya.data.classification}
              stack={kumoriya.data.stack}
              metrics={kumoriya.data.metrics}
              strings={{ refinements: T('common.refinements'), clickToOpen: T('common.clickToOpen') }}
            />
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Other Expedientes (below hero) -->
  {otherExpedientes.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-4">
        <p class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">
          {T('hero.recentExpedients')}
        </p>
        <a href={expedientesHref} class="text-body-sm font-mono text-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] transition-colors" data-seal-react>
          {T('hero.seeAll')}
        </a>
      </div>
      <ScatteredExpedientes
        client:visible
        expedientes={otherExpedientes}
        strings={scatteredStrings}
        basePath="/en/expedientes"
      />
    </section>
  )}

  <!-- Quick links section -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <a href={aboutHref} class="rounded-paper border border-[var(--color-archive-kraft)]/20 p-5 transition-all hover:shadow-paper hover:border-[var(--color-accent-gold)]/30 group" data-seal-react>
        <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] group-hover:text-[var(--color-accent-gold-bright)] transition-colors">{T('hero.quickLinkIdentification')}</p>
        <p class="mt-1 text-body-sm text-[var(--color-text-secondary)]">{T('hero.quickLinkIdentificationDesc')}</p>
      </a>
      <a href={toolsHref} class="rounded-paper border border-[var(--color-archive-kraft)]/20 p-5 transition-all hover:shadow-paper hover:border-[var(--color-accent-gold)]/30 group" data-seal-react>
        <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] group-hover:text-[var(--color-accent-gold-bright)] transition-colors">{T('hero.quickLinkCatalog')}</p>
        <p class="mt-1 text-body-sm text-[var(--color-text-secondary)]">{T('hero.quickLinkCatalogDesc')}</p>
      </a>
      <a href={contactHref} class="rounded-paper border border-[var(--color-archive-kraft)]/20 p-5 transition-all hover:shadow-paper hover:border-[var(--color-accent-gold)]/30 group" data-seal-react>
        <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] group-hover:text-[var(--color-accent-gold-bright)] transition-colors">{T('hero.quickLinkContact')}</p>
        <p class="mt-1 text-body-sm text-[var(--color-text-secondary)]">{T('hero.quickLinkContactDesc')}</p>
      </a>
    </div>
  </section>
</BaseLayout>
