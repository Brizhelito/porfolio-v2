---
import BaseLayout from '@layouts/BaseLayout.astro';
import StackCatalog from '@components/expedientes/StackCatalog';
import { t } from '@lib/i18n';
import { getCollection } from 'astro:content';

const T = (key: string) => t('es', key);

const expedientes = await getCollection('expedientes');

const categoryDefs = [
  { name: 'Frontend', tools: ['React', 'Next.js', 'Astro', 'Tailwind CSS', 'TypeScript', 'JavaScript'] },
  { name: 'Mobile', tools: ['Flutter', 'Dart', 'Provider', 'Riverpod', 'sqflite', 'Go Router', 'FL Chart', 'mobile_scanner'] },
  { name: 'Backend', tools: ['Go (Fiber)', 'Java (Spring Boot)', 'Node.js', 'Maven'] },
  { name: 'Database', tools: ['PostgreSQL', 'Neon', 'SQLite', 'Drift', 'Redis (Upstash)'] },
  { name: 'Edge & Cloud', tools: ['Cloudflare Workers', 'Durable Objects', 'Cloudflare R2', 'Vercel', 'Firebase FCM'] },
  { name: 'DevOps', tools: ['GitHub Actions', 'Docker', 'Sentry'] },
  { name: 'Auth & Security', tools: ['WebAuthn/Passkeys', 'OAuth 2.0', 'Ed25519', 'JWT', 'iron-session', 'bcrypt', 'Zod'] },
  { name: 'Architecture', tools: ['Plugin-first', 'Layered Architecture', 'Repository Pattern', 'Provider Pattern', 'LWW CRDT Sync', 'REST API', 'MVC'] },
];

const toolUsage: Record<string, string[]> = {};
for (const exp of expedientes) {
  for (const tool of (exp.data.stack ?? [])) {
    if (!toolUsage[tool]) toolUsage[tool] = [];
    toolUsage[tool].push(exp.data.title);
  }
}
---

<BaseLayout title={T('tools.pageTitle')}>
  <section class="page-enter mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <p class="font-stamp text-stamp-label text-[var(--color-text-secondary)] mb-2">{T('tools.header')}</p>
      <h1 class="text-display-lg text-[var(--color-text-primary)]">{T('tools.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)]">
        {T('tools.subtitle')}
      </p>
    </header>

    <StackCatalog
      client:visible
      categories={categoryDefs}
      toolUsage={toolUsage}
      locale="es"
    />
  </section>
</BaseLayout>
