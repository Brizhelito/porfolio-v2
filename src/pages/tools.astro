---
import BaseLayout from '@layouts/BaseLayout.astro';
import { t } from '@lib/i18n';
import { getCollection } from 'astro:content';

const T = (key: string) => t('es', key);

const expedientes = await getCollection('expedientes');

// Build category -> expedient mapping
const categoryDefs = [
  { name: 'Frontend', tools: ['React', 'Flutter', 'Astro', 'Tailwind CSS', 'TypeScript', 'Next.js'] },
  { name: 'Mobile', tools: ['Flutter', 'Dart', 'Riverpod', 'Drift/SQLite', 'Firebase'] },
  { name: 'Backend', tools: ['Go', 'Fiber', 'Node.js', 'Express', 'Python'] },
  { name: 'Database', tools: ['PostgreSQL', 'Redis', 'SQLite', 'MongoDB', 'Drift'] },
  { name: 'Edge & Cloud', tools: ['Cloudflare Workers', 'Durable Objects', 'Vercel', 'WebSocket'] },
  { name: 'DevOps', tools: ['Docker', 'GitHub Actions', 'Sentry', 'Nginx'] },
  { name: 'Auth & Security', tools: ['WebAuthn', 'Passkeys', 'OAuth2', 'JWT', 'CRDT'] },
  { name: 'Architecture', tools: ['Plugin-first', 'Microservicios', 'Event-driven', 'CQRS'] },
];

// For each category, find expedientes whose stack contains any of its tools
const categories = categoryDefs.map((cat) => {
  const related = expedientes.filter((exp) =>
    cat.tools.some((tool) =>
      exp.data.stack.some((s) => s.toLowerCase().includes(tool.toLowerCase()) || tool.toLowerCase().includes(s.toLowerCase()))
    )
  );
  return { ...cat, related };
});
---

<BaseLayout title={T('tools.pageTitle')}>
  <section class="page-enter mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-8">
      <p class="font-stamp text-stamp-label text-[var(--color-text-secondary)] mb-2">{T('tools.header')}</p>
      <h1 class="text-display-lg text-[var(--color-text-primary)]">{T('tools.title')}</h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)]">
        {T('tools.subtitle')}
      </p>
    </header>

    <div class="space-y-6">
      {categories.map((cat) => (
        <div class="rounded-paper border border-[var(--color-archive-kraft)]/20 p-5 transition-shadow hover:shadow-paper">
          <h2 class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-3">
            {cat.name}
          </h2>
          <div class="flex flex-wrap gap-2">
            {cat.tools.map((tool) => (
              <span class="inline-block rounded-paper border border-[var(--color-archive-kraft)]/30 bg-[var(--color-bg-secondary)]/50 px-3 py-1 font-mono text-body-sm text-[var(--color-text-primary)]">
                {tool}
              </span>
            ))}
          </div>
          {cat.related.length > 0 && (
            <div class="mt-3 pt-3 border-t border-[var(--color-archive-kraft)]/10">
              <p class="font-stamp text-[10px] tracking-[0.1em] text-[var(--color-text-secondary)] mb-1.5">{T('tools.usedIn')}:</p>
              <div class="flex flex-wrap gap-2">
                {cat.related.map((exp) => (
                  <a
                    href={`/expedientes/${exp.id}`}
                    class="inline-flex items-center gap-1 text-body-sm font-mono text-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] transition-colors"
                    data-seal-react
                  >
                    <span class="text-[10px] opacity-60">{exp.data.expedientNumber}</span>
                    {exp.data.title}
                    <span class="text-[var(--color-accent-gold)] opacity-50">↗</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
