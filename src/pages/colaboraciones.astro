---
import BaseLayout from '@layouts/BaseLayout.astro';
import TechnicalCard from '@components/ui/TechnicalCard';
import Stamp from '@components/ui/Stamp';
import StickyNote from '@components/ui/StickyNote';
import { t } from '@lib/i18n';

const T = (key: string) => t('es', key);

const collaborations = [
  {
    id: 'corpozulia-2024',
    organization: 'Corpozulia',
    role: 'Desarrollador Fullstack (Freelance)',
    period: '2024',
    status: 'green' as const,
    statusLabel: T('common.completed'),
    description:
      'Desarrollo de una plataforma interna para la gestión de inventario y solicitudes operativas como proyecto independiente remunerado. Me encargué del diseño de la arquitectura y la implementación fullstack.',
    contributions: [
      'Digitalización de procesos internos de inventario y solicitudes',
      'Diseño e implementación de la arquitectura fullstack',
      'Mejora de la eficiencia en la gestión de recursos institucionales',
    ],
    stack: ['Java', 'Spring Boot', 'MySQL', 'React', 'Tailwind CSS'],
    fields: [
      { label: 'ORGANIZACIÓN', value: 'Corpozulia' },
      { label: 'ROL', value: 'Desarrollador Fullstack (Freelance)' },
      { label: 'PERIODO', value: '2024' },
      { label: 'MODALIDAD', value: 'Presencial (Machiques)' },
    ],
    anecdote:
      'El equipo de Corpozulia fue excepcionalmente receptivo. La plataforma se implementó en fases sin interrumpir las operaciones diarias.',
  },
];
---

<BaseLayout title={T('collaborations.pageTitle')} description={T('collaborations.pageDescription')}>
  <section class="page-enter mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]">
          {T('collaborations.header')}
        </span>
        <Stamp label={`${collaborations.length} ${T('common.recordsCount')}`} variant="green" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]">
        {T('collaborations.title')}
      </h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl">
        {T('collaborations.subtitle')}
      </p>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <!-- Collaborations list -->
    <div class="space-y-8">
      {collaborations.map((collab) => (
        <article class="relative">
          <!-- Main card -->
          <div class="rounded-paper texture-aged-paper border border-[var(--color-archive-kraft)]/30 p-6 shadow-paper">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h2 class="font-display text-display-sm text-[var(--color-text-primary)]">
                    {collab.organization}
                  </h2>
                  <Stamp label={collab.statusLabel} variant={collab.status} size="sm" animate={false} />
                </div>
                <p class="font-stamp text-stamp-label text-[var(--color-accent-gold)] mb-3">
                  {collab.role} · {collab.period}
                </p>
                <p class="text-body-md text-[var(--color-text-secondary)] mb-4 max-w-xl">
                  {collab.description}
                </p>

                <!-- Contributions -->
                <div class="mb-4">
                  <p class="font-stamp text-stamp-label text-[var(--color-text-secondary)] mb-2">
                    {T('collaborations.keyContributions')}
                  </p>
                  <ul class="space-y-1">
                    {collab.contributions.map((c) => (
                      <li class="flex items-start gap-2 text-body-sm text-[var(--color-text-primary)]">
                        <span class="mt-1 text-[var(--color-accent-gold)]">◆</span>
                        {c}
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Stack -->
                <div class="flex flex-wrap gap-2">
                  {collab.stack.map((tech) => (
                    <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-[var(--color-archive-kraft)]/20 text-[var(--color-text-secondary)]">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Side metadata card -->
              <div class="lg:w-64 shrink-0">
                <TechnicalCard
                  client:visible
                  title={T('common.technicalCard')}
                  fields={collab.fields}
                  stampLabel={collab.statusLabel}
                  stampVariant={collab.status}
                />
              </div>
            </div>
          </div>

          <!-- Sticky note annotation -->
          <div class="mt-4 ml-8">
            <StickyNote client:visible color="yellow" rotation={-1.5}>
              <p class="text-[var(--color-text-primary)]">
                {collab.anecdote ?? 'Colaboración documentada.'}
              </p>
            </StickyNote>
          </div>
        </article>
      ))}
    </div>

    <!-- Open to collabs -->
    <div class="mt-16 rounded-paper border border-dashed border-[var(--color-accent-gold)]/40 p-8 text-center">
      <p class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-2">
        {T('collaborations.interested')}
      </p>
      <p class="text-body-md text-[var(--color-text-secondary)] max-w-md mx-auto mb-4">
        {T('collaborations.interestedText')}
      </p>
      <a
        href="/contacto"
        class="gold-underline inline-block font-stamp text-stamp-label text-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)] transition-colors"
      >
        {T('collaborations.openRequest')}
      </a>
    </div>
  </section>
</BaseLayout>

