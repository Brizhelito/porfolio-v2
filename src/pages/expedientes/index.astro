---
import BaseLayout from '@layouts/BaseLayout.astro';
import FileFolder from '@components/ui/FileFolder';
import Stamp from '@components/ui/Stamp';
import { getCollection } from 'astro:content';

const expedientes = await getCollection('expedientes');
const sorted = [...expedientes].sort((a, b) => b.data.refinementCount - a.data.refinementCount);

const featured = sorted.filter((e) => e.data.status === 'featured');
const active = sorted.filter((e) => e.data.status === 'active');
const archived = sorted.filter((e) => e.data.status === 'archived');
---

<BaseLayout title="Expedientes — Archivo Reny Mireles" description="Todos los expedientes de trabajo abiertos en el archivo">
  <section class="page-enter mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Page header -->
    <header class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <span class="font-stamp text-stamp-label text-[var(--color-text-secondary)]" data-i18n="expedients.archiveTitle">
          ARCHIVO CENTRAL
        </span>
        <Stamp label={`${sorted.length} EXPEDIENTES`} variant="blue" size="md" />
      </div>
      <h1 class="font-display text-display-lg text-[var(--color-text-primary)]" data-i18n="expedients.title">
        Expedientes Abiertos
      </h1>
      <p class="mt-2 text-body-lg text-[var(--color-text-secondary)] max-w-2xl" data-i18n="expedients.subtitle">
        Cada expediente documenta el proceso de ingeniería: decisiones, errores, refinamientos
        y las cicatrices de oro que dejaron.
      </p>
      <div class="mt-6 h-px bg-gradient-to-r from-transparent via-[var(--color-accent-gold)] to-transparent opacity-30" />
    </header>

    <!-- Featured expedients -->
    {featured.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-accent-gold)] mb-4" data-i18n="expedients.featured">
          DESTACADOS
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {featured.map((exp) => (
            <a href={`/expedientes/${exp.id}`} class="block">
              <FileFolder
                client:visible
                title={exp.data.title}
                expedientNumber={exp.data.expedientNumber}
                status={exp.data.status}
                refinementCount={exp.data.refinementCount}
              >
                <p class="text-body-sm text-[var(--color-text-secondary)]">
                  {exp.data.description.slice(0, 120)}...
                </p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {exp.data.stack.slice(0, 5).map((tech) => (
                    <span class="font-mono text-[10px] px-2 py-0.5 rounded bg-[var(--color-archive-kraft)]/10 text-[var(--color-text-secondary)]">
                      {tech}
                    </span>
                  ))}
                </div>
              </FileFolder>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Active expedients -->
    {active.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-text-secondary)] mb-4" data-i18n="expedients.active">
          ACTIVOS
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {active.map((exp) => (
            <a href={`/expedientes/${exp.id}`} class="block">
              <FileFolder
                client:visible
                title={exp.data.title}
                expedientNumber={exp.data.expedientNumber}
                status={exp.data.status}
                refinementCount={exp.data.refinementCount}
              >
                <p class="text-body-sm text-[var(--color-text-secondary)]">
                  {exp.data.description.slice(0, 120)}...
                </p>
              </FileFolder>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Archived expedients -->
    {archived.length > 0 && (
      <div class="mb-12">
        <h2 class="font-stamp text-stamp-title text-[var(--color-text-secondary)]/60 mb-4" data-i18n="expedients.archived">
          ARCHIVADOS
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 opacity-80">
          {archived.map((exp) => (
            <a href={`/expedientes/${exp.id}`} class="block">
              <FileFolder
                client:visible
                title={exp.data.title}
                expedientNumber={exp.data.expedientNumber}
                status={exp.data.status}
                refinementCount={exp.data.refinementCount}
              />
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
