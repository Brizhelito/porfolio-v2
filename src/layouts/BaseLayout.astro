---
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import Seal from '@components/ui/Seal';
import CustomCursor from '@components/ui/CustomCursor';
import { SITE, SITE_I18N, GOOGLE_FONTS_URL } from '@lib/constants';
import { getLocalizedHref, type Locale } from '@lib/i18n';
import '@styles/global.css';
import '@styles/typography.css';
import '@styles/textures.css';
import '@styles/animations.css';
import '@styles/cursor.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  landing?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage,
  locale = 'es',
  landing = false,
} = Astro.props;

const landingScroll = landing ? 'landing-scroll' : '';

const siteMeta = SITE_I18N[locale];
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).href;

// Generate hreflang URLs for both locales
const esUrl = new URL(getLocalizedHref(Astro.url.pathname, 'es'), SITE.url).href;
const enUrl = new URL(getLocalizedHref(Astro.url.pathname, 'en'), SITE.url).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  description: siteMeta.description,
  sameAs: [
    'https://github.com/Brizhelito',
    'https://www.linkedin.com/in/reny-david-mireles-bozo-523147240',
  ],
  jobTitle: 'Software Developer',
  knowsAbout: ['Software Development', 'Flutter', 'Go', 'TypeScript', 'Cloud Architecture', 'Distributed Systems'],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || siteMeta.description} />
    <meta name="author" content={SITE.author} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <!-- Google Fonts — P3-07: preconnect + preload the stylesheet so the
         CSS request fires in parallel with HTML parsing instead of being
         render-blocking. display=swap ensures text is visible during fetch. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={GOOGLE_FONTS_URL} />
    <link href={GOOGLE_FONTS_URL} rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || siteMeta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'es_VE'} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || siteMeta.description} />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Critical CSS: hide hero intro elements until JS orchestrator is ready.
         Inline to prevent FOUC in dev mode (Vite loads CSS via JS injection). -->
    <style>
      [data-hero-orchestrator]{visibility:hidden;opacity:0}
      @media(prefers-reduced-motion:reduce){[data-hero-orchestrator]{visibility:visible!important;opacity:1!important}}
    </style>
  </head>
  <body class:list={['min-h-screen bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] transition-colors duration-300', landing && 'overflow-hidden h-dvh']}>
    <Header locale={locale} />
    {landing ? (
      <main class:list={['relative z-[var(--z-content)]', landingScroll]}>
        <slot />
        <Footer locale={locale} />
      </main>
    ) : (
      <>
        <main class="relative z-[var(--z-content)]">
          <slot />
        </main>
        <Footer locale={locale} />
      </>
    )}
    <Seal client:idle locale={locale} />
    <CustomCursor client:load />
  </body>
</html>
