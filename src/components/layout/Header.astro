---
import { NAV_LINKS } from '@lib/constants';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-[var(--z-navigation)] border-b border-[var(--color-bg-secondary)] bg-[var(--color-bg-primary)]/95 backdrop-blur-sm transition-colors duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo / Monogram -->
    <a
      href="/"
      class="font-display text-xl font-semibold tracking-tight text-[var(--color-text-primary)] transition-colors hover:text-[var(--color-accent-gold)]"
    >
      <span class="text-gold-gradient">RM</span>
      <span class="ml-2 hidden text-sm text-[var(--color-text-secondary)] sm:inline font-stamp">ARCHIVO</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'rounded-paper px-3 py-1.5 text-body-sm font-medium transition-colors duration-200',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'bg-[var(--color-bg-secondary)] text-[var(--color-accent-gold)]'
              : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
          ]}
        >
          {label}
        </a>
      ))}

      <!-- Theme Toggle (inline) -->
      <button
        id="theme-toggle"
        class="ml-2 rounded-paper p-2 text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-accent-gold)]"
        aria-label="Cambiar tema"
      >
        <svg class="h-5 w-5 hidden dark-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="h-5 w-5 light-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="rounded-paper p-2 text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] md:hidden"
      aria-label="Abrir menú"
    >
      <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-bg-secondary)] bg-[var(--color-bg-primary)] px-4 pb-4 md:hidden">
    {NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'block rounded-paper px-3 py-2 text-body-md transition-colors',
          currentPath === href
            ? 'text-[var(--color-accent-gold)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
        ]}
      >
        {label}
      </a>
    ))}
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  /* Toggle icon visibility based on theme */
  [data-theme='dark'] .light-icon { display: none; }
  [data-theme='dark'] .dark-icon { display: block !important; }
  [data-theme='light'] .dark-icon { display: none; }
  [data-theme='light'] .light-icon { display: block !important; }
</style>
