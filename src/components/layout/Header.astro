---
import { NAV_LINKS } from '@lib/constants';
import LanguageSwitch from '@components/ui/LanguageSwitch';

const currentPath = Astro.url.pathname;
---

<header class="archive-header sticky top-0 z-[var(--z-navigation)]">
  <!-- Top accent line -->
  <div class="h-[3px] bg-gradient-to-r from-[var(--color-archive-kraft)] via-[var(--color-accent-gold)] to-[var(--color-archive-kraft)]"></div>

  <nav class="relative bg-[var(--color-bg-primary)] border-b border-[var(--color-archive-kraft)]/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        
        <!-- Left: Logo + Archive label -->
        <div class="flex items-center gap-3">
          <a href="/" class="group flex items-center gap-2.5">
            <!-- Sello RM -->
            <div class="seal-logo relative w-10 h-10 flex items-center justify-center">
              <svg viewBox="0 0 100 100" class="w-full h-full">
                <polygon
                  points="30,5 70,5 95,30 95,70 70,95 30,95 5,70 5,30"
                  fill="none"
                  stroke="var(--color-accent-gold)"
                  stroke-width="3"
                  class="transition-all duration-300 group-hover:stroke-[var(--color-accent-gold-bright)]"
                />
                <text
                  x="50" y="58"
                  text-anchor="middle"
                  font-family="'IBM Plex Serif', serif"
                  font-size="28" font-weight="600"
                  fill="var(--color-accent-gold)"
                  class="transition-all duration-300 group-hover:fill-[var(--color-accent-gold-bright)]"
                >RM</text>
              </svg>
            </div>
            <div class="hidden sm:block">
              <span class="font-stamp text-[10px] tracking-[0.15em] text-[var(--color-text-secondary)] block leading-none">
                ARCHIVO
              </span>
              <span class="font-display text-sm font-semibold text-[var(--color-text-primary)] leading-tight">
                Reny Mireles
              </span>
            </div>
          </a>
        </div>

        <!-- Center: Navigation (desktop) -->
        <div class="hidden md:flex items-center gap-0.5">
          {NAV_LINKS.map(({ href, label, i18n }) => {
            const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
            return (
              <a
                href={href}
                data-i18n={i18n}
                class:list={[
                  'nav-link relative px-3 py-2 text-[13px] font-medium tracking-wide transition-all duration-200',
                  isActive
                    ? 'text-[var(--color-accent-gold)]'
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
                ]}
              >
                {label}
                {isActive && (
                  <span class="absolute bottom-0 left-3 right-3 h-[2px] bg-[var(--color-accent-gold)] rounded-full"></span>
                )}
              </a>
            );
          })}
        </div>

        <!-- Right: Language Switch + Mobile menu -->
        <div class="flex items-center gap-2">
          <span id="lang-switch-wrap"><LanguageSwitch client:load /></span>
          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="mobile-menu-btn md:hidden w-9 h-9 flex items-center justify-center rounded-[3px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)]/50 transition-colors"
            aria-label="Abrir menú"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="mobile-drawer hidden md:hidden border-t border-[var(--color-archive-kraft)]/30 bg-[var(--color-bg-primary)]">
      <div class="px-4 py-3 space-y-1">
        {NAV_LINKS.map(({ href, label, i18n }) => {
          const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
          return (
            <a
              href={href}
              data-i18n={i18n}
              class:list={[
                'flex items-center gap-3 px-3 py-2.5 rounded-[3px] text-sm transition-colors',
                isActive
                  ? 'bg-[var(--color-bg-secondary)]/60 text-[var(--color-accent-gold)] font-medium'
                  : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)]/30 hover:text-[var(--color-text-primary)]',
              ]}
            >
              {isActive && (
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-gold)]"></span>
              )}
              <span class:list={[!isActive && 'ml-[18px]']}>{label}</span>
            </a>
          );
        })}
      </div>
      <!-- Mobile archive stamp -->
      <div class="px-4 py-3 border-t border-[var(--color-archive-kraft)]/20">
        <p class="font-stamp text-[10px] tracking-[0.12em] text-[var(--color-text-secondary)]/60 text-center">
          ARCHIVO RENY MIRELES — {new Date().getFullYear()}
        </p>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    
    // Animate hamburger to X
    const svg = menuBtn.querySelector('svg');
    const paths = svg?.querySelectorAll('path');
    if (paths && paths.length >= 2) {
      if (!isOpen) {
        paths[0].setAttribute('d', 'M6 6l12 12');
        paths[1].setAttribute('d', 'M6 18L18 6');
      } else {
        paths[0].setAttribute('d', 'M3.75 6.75h16.5');
        paths[1].setAttribute('d', 'M3.75 12h16.5m-16.5 5.25h16.5');
      }
    }
  });
</script>

<style>
  .archive-header {
    background: var(--color-bg-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent-gold);
    transition: all 0.2s ease;
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  .lang-btn {
    position: relative;
    overflow: hidden;
  }

  .lang-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
  }

  .lang-btn:hover::before {
    transform: scaleX(1);
  }

  .seal-logo {
    transition: transform 0.3s ease;
  }

  .seal-logo:hover {
    transform: rotate(-3deg) scale(1.05);
  }

  .mobile-drawer {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
