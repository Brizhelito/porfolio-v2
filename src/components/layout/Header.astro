---
import { NAV_LINKS } from '@lib/constants';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-[var(--z-navigation)] border-b border-[var(--color-bg-secondary)] bg-[var(--color-bg-primary)]/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo / Monogram -->
    <a
      href="/"
      class="font-display text-xl font-semibold tracking-tight text-[var(--color-text-primary)] transition-colors hover:text-[var(--color-accent-gold)]"
    >
      <span class="text-gold-gradient">RM</span>
      <span class="ml-2 hidden text-sm text-[var(--color-text-secondary)] sm:inline font-stamp">ARCHIVO</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'rounded-paper px-3 py-1.5 text-body-sm font-medium transition-colors duration-200',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'bg-[var(--color-bg-secondary)] text-[var(--color-accent-gold)]'
              : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="rounded-paper p-2 text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] md:hidden"
      aria-label="Abrir menú"
    >
      <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-bg-secondary)] bg-[var(--color-bg-primary)] px-4 pb-4 md:hidden">
    {NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'block rounded-paper px-3 py-2 text-body-md transition-colors',
          currentPath === href
            ? 'text-[var(--color-accent-gold)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
        ]}
      >
        {label}
      </a>
    ))}
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
