---
import { NAV_LINKS } from '@lib/constants';
import LanguageSwitch from '@components/ui/LanguageSwitch';
import CursorToggle from '@components/ui/CursorToggle';
import { t, getLocalizedHref, type Locale } from '@lib/i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'es' } = Astro.props;
const currentPath = Astro.url.pathname;

// Determine if this is the landing page (navbar hidden by default)
const isLanding = currentPath === '/' || currentPath === '/en' || currentPath === '/en/';

// Map href to the correct i18n nav key (handles /contacto -> nav.contact)
const HREF_TO_NAV_KEY: Record<string, string> = {
  '/': 'home',
  '/about': 'about',
  '/tools': 'tools',
  '/expedientes': 'expedients',
  '/contacto': 'contact',
  '/colaboraciones': 'collaborations',
  '/inspiraciones': 'inspirations',
};

function getNavKey(href: string): string {
  return HREF_TO_NAV_KEY[href] ?? href.slice(1).replace(/\//g, '');
}

const contactHref = getLocalizedHref('/contacto', locale);
const contactLabel = t(locale, 'nav.contact');
---

<header
  id="archive-header"
  class:list={[
    'archive-header fixed top-0 left-0 right-0 z-[var(--z-navigation)] transition-transform duration-300 ease-out',
    isLanding ? '-translate-y-full' : 'translate-y-0',
  ]}
  data-landing={isLanding ? 'true' : 'false'}
>
  <!-- Top accent line -->
  <div class="h-[3px] bg-gradient-to-r from-[var(--color-archive-kraft)] via-[var(--color-accent-gold)] to-[var(--color-archive-kraft)]"></div>

  <nav class="relative bg-[var(--color-bg-primary)]/95 backdrop-blur-sm border-b border-[var(--color-archive-kraft)]/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        
        <!-- Left: Logo + Archive label -->
        <div class="flex items-center gap-3">
          <a href={getLocalizedHref('/', locale)} class="group flex items-center gap-2.5" data-seal-react>
            <!-- Sello RM -->
            <div class="seal-logo relative w-10 h-10 flex items-center justify-center">
              <svg viewBox="0 0 100 100" class="w-full h-full">
                <polygon
                  points="30,5 70,5 95,30 95,70 70,95 30,95 5,70 5,30"
                  fill="none"
                  stroke="var(--color-accent-gold)"
                  stroke-width="3"
                  class="transition-all duration-300 group-hover:stroke-[var(--color-accent-gold-bright)]"
                />
                <text
                  x="50" y="58"
                  text-anchor="middle"
                  font-family="'IBM Plex Serif', serif"
                  font-size="28" font-weight="600"
                  fill="var(--color-accent-gold)"
                  class="transition-all duration-300 group-hover:fill-[var(--color-accent-gold-bright)]"
                >RM</text>
              </svg>
            </div>
            <div class="hidden sm:block">
              <span class="font-stamp text-[10px] tracking-[0.15em] text-[var(--color-text-secondary)] block leading-none">
                {locale === 'en' ? 'ARCHIVE' : 'ARCHIVO'}
              </span>
              <span class="font-display text-sm font-semibold text-[var(--color-text-primary)] leading-tight">
                Reny Mireles
              </span>
            </div>
          </a>
        </div>

        <!-- Center: Navigation (desktop) -->
        <div class="hidden md:flex items-center gap-0.5">
          {NAV_LINKS.map(({ href }) => {
            const localizedHref = getLocalizedHref(href, locale);
            const navKey = getNavKey(href);
            const navLabel = t(locale, `nav.${navKey}`);
            const isActive = currentPath === localizedHref || (localizedHref !== getLocalizedHref('/', locale) && currentPath.startsWith(localizedHref));
            return (
              <a
                href={localizedHref}
                class:list={[
                  'nav-link relative px-3 py-2 text-[13px] font-medium tracking-wide transition-all duration-200',
                  isActive
                    ? 'text-[var(--color-accent-gold)]'
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
                ]}
                data-seal-react
              >
                {navLabel}
                {isActive && (
                  <span class="absolute bottom-0 left-3 right-3 h-[2px] bg-[var(--color-accent-gold)] rounded-full"></span>
                )}
              </a>
            );
          })}
        </div>

        <!-- Right: Contact CTA + Language Switch + Mobile menu -->
        <div class="flex items-center gap-2">
          <!-- Contact pill button (desktop) -->
          <a
            href={contactHref}
            class="hidden md:inline-flex items-center gap-1.5 rounded-full border border-[var(--color-accent-gold)]/60 bg-[var(--color-accent-gold)]/10 px-3.5 py-1.5 text-[12px] font-semibold tracking-wide text-[var(--color-accent-gold)] transition-all hover:bg-[var(--color-accent-gold)]/20 hover:border-[var(--color-accent-gold)] hover:text-[var(--color-accent-gold-bright)]"
            data-seal-react
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            {contactLabel}
          </a>
          <CursorToggle client:load />
          <LanguageSwitch client:load currentPath={currentPath} locale={locale} />
          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="mobile-menu-btn md:hidden w-9 h-9 flex items-center justify-center rounded-[3px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)]/50 transition-colors"
            aria-label={locale === 'en' ? 'Open menu' : 'Abrir menú'}
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="mobile-drawer hidden md:hidden border-t border-[var(--color-archive-kraft)]/30 bg-[var(--color-bg-primary)]">
      <div class="px-4 py-3 space-y-1">
        {NAV_LINKS.map(({ href }) => {
          const localizedHref = getLocalizedHref(href, locale);
          const navKey = getNavKey(href);
          const navLabel = t(locale, `nav.${navKey}`);
          const isActive = currentPath === localizedHref || (localizedHref !== getLocalizedHref('/', locale) && currentPath.startsWith(localizedHref));
          return (
            <a
              href={localizedHref}
              class:list={[
                'flex items-center gap-3 px-3 py-2.5 rounded-[3px] text-sm transition-colors',
                isActive
                  ? 'bg-[var(--color-bg-secondary)]/60 text-[var(--color-accent-gold)] font-medium'
                  : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)]/30 hover:text-[var(--color-text-primary)]',
              ]}
            >
              {isActive && (
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-gold)]"></span>
              )}
              <span class:list={[!isActive && 'ml-[18px]']}>
                {navLabel}
              </span>
            </a>
          );
        })}
        <!-- Mobile contact link -->
        <a
          href={contactHref}
          class="flex items-center gap-3 px-3 py-2.5 rounded-[3px] text-sm text-[var(--color-accent-gold)] hover:bg-[var(--color-accent-gold)]/10 transition-colors font-medium"
        >
          <svg class="h-4 w-4 ml-[2px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="ml-[2px]">{contactLabel}</span>
        </a>
      </div>
      <!-- Mobile archive stamp -->
      <div class="px-4 py-3 border-t border-[var(--color-archive-kraft)]/20">
        <p class="font-stamp text-[10px] tracking-[0.12em] text-[var(--color-text-secondary)]/60 text-center">
          {locale === 'en' ? 'RENY MIRELES ARCHIVE' : 'ARCHIVO RENY MIRELES'} — {new Date().getFullYear()}
        </p>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('archive-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const isLanding = header?.dataset.landing === 'true';

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    const svg = menuBtn.querySelector('svg');
    const paths = svg?.querySelectorAll('path');
    if (paths && paths.length >= 2) {
      if (!isOpen) {
        paths[0].setAttribute('d', 'M6 6l12 12');
        paths[1].setAttribute('d', 'M6 18L18 6');
      } else {
        paths[0].setAttribute('d', 'M3.75 6.75h16.5');
        paths[1].setAttribute('d', 'M3.75 12h16.5m-16.5 5.25h16.5');
      }
    }
  });

  // Scroll-aware navbar: hide/show on landing page only
  if (isLanding && header) {
    let lastScrollY = 0;
    let ticking = false;
    const SHOW_THRESHOLD = 80;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        const scrollY = window.scrollY;
        if (scrollY > SHOW_THRESHOLD) {
          header.classList.remove('-translate-y-full');
          header.classList.add('translate-y-0');
        } else {
          header.classList.remove('translate-y-0');
          header.classList.add('-translate-y-full');
        }
        lastScrollY = scrollY;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .archive-header {
    background: var(--color-bg-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent-gold);
    transition: all 0.2s ease;
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  .seal-logo {
    transition: transform 0.3s ease;
  }

  .seal-logo:hover {
    transform: rotate(-3deg) scale(1.05);
  }

  .mobile-drawer {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
